# Required system auth
SYSTEM_WS_TOKEN=

# Bot context
BOT_ID=

# Connectivity
SYSTEM_WS_URL=ws://200.200.201.4:8081/ws/signals

# Exchange execution settings
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=
EXCHANGE_SANDBOX=true
EXCHANGE_DEFAULT_TYPE=
DEFAULT_ORDER_AMOUNT=0.001
DEFAULT_ORDER_TYPE=market
EXECUTION_MODE=dry-run

# Runtime tuning
HEARTBEAT_INTERVAL_SECONDS=15
HEARTBEAT_TIMEOUT_SECONDS=10
HEARTBEAT_STALE_SECONDS=45
RECONNECT_INITIAL_DELAY_SECONDS=1
RECONNECT_MAX_DELAY_SECONDS=30
PROTOCOL_VERSION=1.0
HANDSHAKE_ACK_REQUIRED=true
HANDSHAKE_ACK_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO
