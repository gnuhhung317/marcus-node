# Required trader credentials (used in next execution tasks)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# Required system auth
SYSTEM_WS_TOKEN=

# Bot context for state re-sync
BOT_ID=

# Connectivity
SYSTEM_WS_URL=ws://localhost:8080/ws/signals
CMS_BASE_URL=http://localhost:8080
SYSTEM_HTTP_TOKEN=

# Runtime tuning
HEARTBEAT_INTERVAL_SECONDS=15
HEARTBEAT_TIMEOUT_SECONDS=10
HEARTBEAT_STALE_SECONDS=45
RECONNECT_INITIAL_DELAY_SECONDS=1
RECONNECT_MAX_DELAY_SECONDS=30
REQUEST_TIMEOUT_SECONDS=10
PROTOCOL_VERSION=1.0
HANDSHAKE_ACK_REQUIRED=true
HANDSHAKE_ACK_TIMEOUT_SECONDS=5
SSL_VERIFY=true
LOG_LEVEL=INFO
